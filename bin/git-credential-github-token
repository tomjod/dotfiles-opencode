#!/bin/sh
# Git credential helper for GitHub via GITHUB_TOKEN env var
# Works in bash, fish, zsh — reads token from environment at runtime
# Usage: git config --global credential.helper /home/$USER/.local/bin/git-credential-github-token

while IFS= read -r line; do
    [ -z "$line" ] && break
    case "$line" in
        host=*) host="${line#host=}" ;;
    esac
done

if [ "$host" = "github.com" ] && [ -n "$GITHUB_TOKEN" ]; then
    echo "username=tomjod"
    echo "password=${GITHUB_TOKEN}"
fi
