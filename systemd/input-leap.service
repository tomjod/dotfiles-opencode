[Unit]
Description=Input Leap — Keyboard/Mouse Sharing
Documentation=https://github.com/input-leap/input-leap
Wants=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStart=/home/mv/Downloads/input-leap-ubuntu-24-04-v3.0.3/input-leap-ubuntu-24-04/input-leap-ubuntu-24-04/bin/input-leap
